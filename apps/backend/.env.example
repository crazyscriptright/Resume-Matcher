# ===========================================
# LEGACY LLM Configuration (Single Provider)
# ===========================================
# Note: For single-model setup, use these. For multi-model routing with
# fallbacks and quota tracking, configure the sections below instead.
# 
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-5-nano-2025-08-07
# LLM_API_KEY=sk-your-api-key-here
# LLM_API_BASE=  # Optional for custom endpoints

# ===========================================
# NEW: Multi-Model LLM Routing with Quota Limits
# ===========================================
# One API key per provider, shared across ALL models of that provider.
# Each model has its own tier quota limits.
# Leave empty or 0 to mean UNLIMITED.

# -------- GEMINI API KEYS --------
# Shared by: Gemini Lite, Gemini Flash, Gemini 3
GEMINI_API_KEY_1=your-gemini-api-key-1
# GEMINI_API_KEY_2=your-gemini-api-key-2
# GEMINI_API_KEY_3=your-gemini-api-key-3
# GEMINI_API_KEY_4=your-gemini-api-key-4

# -------- OPENAI API KEYS --------
# Shared by: GPT-5-Pro, GPT-5-Mini, GPT-4.1-Mini, GPT-5-Nano, GPT-4o-Mini
OPENAI_API_KEY_1=sk-your-openai-api-key-1
# OPENAI_API_KEY_2=sk-your-openai-api-key-2

# ==========================================
# MODEL CONFIGURATION - Tier 1-8
# ==========================================
# Format: LLM_MODEL_N_NAME, PROVIDER, PRIORITY, TPM, RPM, RPD, TPD
# Priority: 1=highest (try first), 8=lowest (fallback)
# Limits: Leave empty or 0 = UNLIMITED
#
# Rules:
# - TPM (tokens/min) → checked hourly, resets at :00
# - RPM (requests/min) → checked hourly, resets at :00
# - RPD (requests/day) → checked daily, resets at midnight UTC
# - TPD (tokens/day) → checked daily, resets at midnight UTC


# Tier 1: GPT-5-PRO (Premium - Strict limits)
LLM_MODEL_1_NAME=gpt-5-pro-2025-10-06
LLM_MODEL_1_PROVIDER=openai
LLM_MODEL_1_PRIORITY=1
LLM_MODEL_1_TPM=30000
LLM_MODEL_1_RPM=3
LLM_MODEL_1_RPD=200
LLM_MODEL_1_TPD=90000

# Tier 2: GEMINI-3-FLASH (Fast - Moderate limits)
LLM_MODEL_2_NAME=gemini-3-flash
LLM_MODEL_2_PROVIDER=gemini
LLM_MODEL_2_PRIORITY=2
LLM_MODEL_2_TPM=250000
LLM_MODEL_2_RPM=5
LLM_MODEL_2_RPD=20

# Tier 3: GPT-5-MINI
LLM_MODEL_3_NAME=gpt-5-mini-2025-08-07
LLM_MODEL_3_PROVIDER=openai
LLM_MODEL_3_PRIORITY=3
LLM_MODEL_3_TPM=60000
LLM_MODEL_3_RPM=3
LLM_MODEL_3_RPD=200
LLM_MODEL_3_TPD=200000

# Tier 4: GPT-4.1-MINI
LLM_MODEL_4_NAME=gpt-4.1-mini-2025-04-14
LLM_MODEL_4_PROVIDER=openai
LLM_MODEL_4_PRIORITY=4
LLM_MODEL_4_TPM=60000
LLM_MODEL_4_RPM=3
LLM_MODEL_4_RPD=200
LLM_MODEL_4_TPD=200000

# Tier 5: GEMINI-2.5-FLASH
LLM_MODEL_5_NAME=gemini-2.5-flash
LLM_MODEL_5_PROVIDER=gemini
LLM_MODEL_5_PRIORITY=5
LLM_MODEL_5_TPM=250000
LLM_MODEL_5_RPM=5
LLM_MODEL_5_RPD=20

# Tier 6: GPT-5-NANO (With daily limits)
LLM_MODEL_6_NAME=gpt-5-nano-2025-08-07
LLM_MODEL_6_PROVIDER=openai
LLM_MODEL_6_PRIORITY=6
LLM_MODEL_6_TPM=40000
LLM_MODEL_6_RPM=3
LLM_MODEL_6_RPD=200
LLM_MODEL_6_TPD=200000

# Tier 7: GEMINI-2.5-FLASH-LITE (Very strict RPM)
LLM_MODEL_7_NAME=gemini-2.5-flash-lite
LLM_MODEL_7_PROVIDER=gemini
LLM_MODEL_7_PRIORITY=7
LLM_MODEL_7_TPM=250000
LLM_MODEL_7_RPM=5
LLM_MODEL_7_RPD=20

# Tier 8: GPT-4O-MINI (Last fallback)
LLM_MODEL_8_NAME=gpt-4o-mini-2024-07-18
LLM_MODEL_8_PROVIDER=openai
LLM_MODEL_8_PRIORITY=8
LLM_MODEL_8_TPM=60000
LLM_MODEL_8_RPM=3
LLM_MODEL_8_RPD=200
LLM_MODEL_8_TPD=200000

# ===========================================
# Server Configuration
# ===========================================
HOST=0.0.0.0
PORT=8000
# Set RELOAD=true for `uv run app` to auto-reload on file changes (dev only)
RELOAD=false
# Reasoning effort for models that support it: minimal | low | medium | high
# Leave unset (or blank) for maximum provider compatibility. LiteLLM will
# drop this parameter for providers that don't support it.
# REASONING_EFFORT=
LOG_LEVEL=INFO
LOG_LLM=WARNING

# Frontend URL - Used for PDF generation
FRONTEND_BASE_URL=http://localhost:3000

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ===========================================
# Database Configuration
# ===========================================
# Leave empty or unset for local TinyDB (development)
# For PostgreSQL (production/multi-user):
#   DATABASE_URL=postgresql://user:password@localhost:5432/resumematcher
# For SQLite (testing):
#   DATABASE_URL=sqlite:///./test.db
# 
# Examples:
# PostgreSQL on Heroku:
#   DATABASE_URL=postgresql://user:password@ec2-xxx.compute-1.amazonaws.com:5432/d8xxx
# PostgreSQL locally:
#   DATABASE_URL=postgresql://postgres:mypassword@localhost:5432/resumematcher
# 
DATABASE_URL=

# ===========================================
# JWT Configuration
# ===========================================
# Secret key for signing JWT tokens (minimum 32 characters, use a secure random string)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-here-minimum-32-characters
