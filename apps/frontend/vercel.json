{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_API_URL": "@next_public_api_url"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "$NEXT_PUBLIC_API_URL/api/:path*"
    },
    {
      "source": "/docs",
      "destination": "$NEXT_PUBLIC_API_URL/docs"
    },
    {
      "source": "/redoc",
      "destination": "$NEXT_PUBLIC_API_URL/redoc"
    },
    {
      "source": "/openapi.json",
      "destination": "$NEXT_PUBLIC_API_URL/openapi.json"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ]
}
